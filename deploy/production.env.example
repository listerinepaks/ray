# Copy to the server (e.g. /opt/ray/.env) and adjust.
# Load before Gunicorn / shell: set -a && source /opt/ray/.env && set +a
#
# --- required in production (DJANGO_DEBUG=0) ---
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=ray.wright5.us,localhost,127.0.0.1
#
# --- trust the public site origin (HTTPS) for CSRF / session ---
DJANGO_CSRF_TRUSTED_ORIGINS=https://ray.wright5.us
DJANGO_CORS_ALLOWED_ORIGINS=https://ray.wright5.us
#
# --- optional: separate API host for the web app build ---
# Normally leave unset: the Vite app on https://ray.wright5.us calls /api on the same origin.
# VITE_API_URL=https://ray.wright5.us
#
# --- optional: private S3-compatible media storage ---
# Leave unset to keep using local /opt/ray/media.
# DJANGO_STORAGE_BACKEND=s3
# AWS_STORAGE_BUCKET_NAME=ray-media
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=us-east-1
# Optional for non-AWS S3 APIs
# AWS_S3_ENDPOINT_URL=
# Optional CDN/custom hostname for media URLs
# AWS_S3_CUSTOM_DOMAIN=
# Signed URL lifetime in seconds
# AWS_QUERYSTRING_EXPIRE=3600
# TLS verification for the S3 endpoint (1=yes, 0=no)
# AWS_S3_VERIFY=1
