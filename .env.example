# Copy to `.env` and load before Django (e.g. `set -a && source .env && set +a`, or systemd EnvironmentFile).
# Django does not auto-load this file unless you add python-dotenv or similar.

# 1 = local dev (default), 0 = production
DJANGO_DEBUG=1

# Required when DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=

# Comma-separated; production includes ray.wright5.us by default in code if unset
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,ray.wright5.us

# Optional overrides (comma-separated HTTPS origins)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://ray.wright5.us
# DJANGO_CORS_ALLOWED_ORIGINS=https://ray.wright5.us

# Optional: when DEBUG=1, set to 0 to stop using ALLOWED_HOSTS=*
# RAY_ALLOW_ALL_HOSTS=1

# Optional media storage backend
# Leave unset for local filesystem storage under ./media.
# Set to `s3` to store uploaded photos in a private S3-compatible bucket.
# DJANGO_STORAGE_BACKEND=s3
# AWS_STORAGE_BUCKET_NAME=ray-media
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=us-east-1
# Optional for S3-compatible providers (Cloudflare R2, Backblaze B2, MinIO, etc.)
# AWS_S3_ENDPOINT_URL=
# Optional CDN/custom hostname in front of the bucket
# AWS_S3_CUSTOM_DOMAIN=
# Signed URL lifetime in seconds
# AWS_QUERYSTRING_EXPIRE=3600
# TLS verification for the S3 endpoint (1=yes, 0=no)
# AWS_S3_VERIFY=1
